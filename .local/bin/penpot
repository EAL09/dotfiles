#!/usr/bin/env bash

compose_path="$HOME/docker/penpot/compose.yaml"
docker_sock="/var/run/docker.sock"

penpot_down(){
	[[ ! -S $docker_sock ]] && exit;
	[[ -S $docker_sock ]] &&\
		[ $(docker ps --filter "name=penpot" | wc -l) -gt 1 ]&&\
		$(docker compose -f "$compose_path" down) && exit;

}
# Take penpot down dep. on argument
if [[ "$1" == "down" ]]; then penpot_down; fi


# Run docker if it isn't already
[[ ! -S $docker_sock  ]] &&\
	{ echo "starting dockerd";
	exec dockerd 1> /dev/null 2> /dev/null & disown;
	sleep 1 ;}


if [ $(docker ps --filter "name=penpot" | wc -l) -ge 1 ];
	then $(docker compose -f "$compose_path" up -d);
fi
